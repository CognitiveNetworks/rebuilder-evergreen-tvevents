# Environment variables for local development
# Copy to .env and fill in values: cp .env.example .env

# --- Required ---
ENV=dev
LOG_LEVEL=DEBUG
AWS_REGION=us-east-1
TEST_CONTAINER=true
SERVICE_NAME=evergreen-tvevents
OTEL_PYTHON_AUTO_INSTRUMENTATION_ENABLED=false

# --- Security ---
T1_SALT=local-dev-salt-value

# --- RDS (not required when TEST_CONTAINER=true) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tvevents
DB_USER=tvevents
DB_PASSWORD=localdev

# --- Kafka (not required when TEST_CONTAINER=true) ---
KAFKA_BROKERS=localhost:9092

# --- Kafka Topics ---
KAFKA_TOPIC_EVERGREEN=evergreen-tvevents
KAFKA_TOPIC_LEGACY=legacy-tvevents
KAFKA_TOPIC_EVERGREEN_DEBUG=evergreen-tvevents-debug
KAFKA_TOPIC_LEGACY_DEBUG=legacy-tvevents-debug

# --- Feature Flags ---
SEND_EVERGREEN=true
SEND_LEGACY=false
TVEVENTS_DEBUG=false

# --- Blacklist Cache ---
BLACKLIST_CHANNEL_IDS_CACHE_FILEPATH=/tmp/.blacklisted_channel_ids_cache

# --- App ---
ZOO=local
VERSION=1.0.0

# --- OTEL (only when OTEL_PYTHON_AUTO_INSTRUMENTATION_ENABLED=true) ---
# OTEL_PYTHON_LOG_FORMAT=%(msg)s [trace_id=%(otelTraceID)s span_id=%(otelSpanID)s]
# OTEL_EXPORTER_OTLP_HEADERS=api-key=YOUR_KEY
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_PYTHON_LOG_CORRELATION=true
# OTEL_ATTRIBUTE_VALUE_LENGTH_LIMIT=4095
# OTEL_INSTRUMENTATION_HTTP_CAPTURE_HEADERS_SERVER_REQUEST=content-type
# OTEL_EXPORTER_OTLP_COMPRESSION=gzip
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
