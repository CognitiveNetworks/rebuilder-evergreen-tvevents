# tvevents-k8s environment variables

# Application
ENV=development
LOG_LEVEL=INFO
T1_SALT=your-t1-salt-value-here

# RDS
RDS_HOST=localhost
RDS_DB=tvevents
RDS_USER=postgres
RDS_PASS=postgres
RDS_PORT=5432

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Kafka Topics
KAFKA_TOPIC_EVERGREEN=tveoe-evergreen
KAFKA_TOPIC_LEGACY=tveoe-legacy
KAFKA_TOPIC_DEBUG_EVERGREEN=tveoe-debug-evergreen
KAFKA_TOPIC_DEBUG_LEGACY=tveoe-debug-legacy

# Feature Flags
SEND_EVERGREEN=true
SEND_LEGACY=true
TVEVENTS_DEBUG=false

# AWS
AWS_REGION=us-east-1

# OTEL
OTEL_ENABLED=true
OTEL_SERVICE_NAME=tvevents-k8s
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.nr-data.net:443
OTEL_EXPORTER_OTLP_HEADERS=api-key=your-new-relic-api-key

# Uvicorn
UVICORN_WORKERS=4

# Cache
BLACKLIST_CACHE_FILEPATH=/tmp/.blacklisted_channel_ids_cache
