# Service
SERVICE_NAME=rebuilder-evergreen-tvevents
ZOO=development
DEBUG=false
LOG_LEVEL=INFO

# HMAC Authentication
T1_SALT=your-hmac-salt-here

# PostgreSQL (RDS)
RDS_HOST=localhost
RDS_DB=tvevents
RDS_USER=tvevents
RDS_PASS=tvevents_dev
RDS_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_DB=0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=tvevents
KAFKA_DEBUG_TOPIC=tvevents-debug
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_DELIVERY_ENABLED=true

# Feature Flags
TVEVENTS_DEBUG=false
SEND_EVERGREEN=true
LEGACY_FIREHOSE_BRIDGE_ENABLED=false

# Cache
BLACKLIST_CACHE_TTL=300

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_SERVICE_NAME=rebuilder-evergreen-tvevents
